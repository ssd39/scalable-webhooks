# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Glacias API"
APP_VERSION="0.1.0"
APP_DEBUG=false
APP_PORT=8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=glacias
POSTGRES_USER=glacias
POSTGRES_PASSWORD=glacias

# ── Redis ─────────────────────────────────────────────────────────────────────
