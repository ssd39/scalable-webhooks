REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Queue ─────────────────────────────────────────────────────────────────────
WEBHOOK_QUEUE_NAME=webhook_tasks

# ── Anthropic LLM (via LangChain) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
